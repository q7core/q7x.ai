# q7x.ai Configuration
# Copy to .env and fill in your values

# ── Authentication (choose one) ─────────────────────────
# Option A: API Key (pay-per-token, required for business use)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: Subscription auth (personal use)
# Run `claude login` on the host and the SDK picks it up automatically.
# No env var needed.

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
ALLOWED_USERS=123456789          # Comma-separated Telegram user IDs

# ── Agent ────────────────────────────────────────────────
AGENT_WORKSPACE=/home/q7x/workspace   # Directory where the agent can operate
MAX_BUDGET_USD=0.50                    # Cost cap per query (API key mode only)
SESSION_TIMEOUT_MINUTES=60             # Auto-resume window

# ── Ollama (local LLM) ──────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ── Database ─────────────────────────────────────────────
SQLITE_PATH=~/.q7x/memory.db
